import gradio as gr

# AI response logic (converted from your dictionary)
def assistant(user_input):
    user_input = user_input.lower()

    responses = {
        "math": "Mathematics is the language of AI. Focus on Linear Algebra and Calculus!",
        "physics": "Physics helps us understand how AI can interact with the real world.",
        "ai": "Artificial Intelligence is the future! You are on the right track."
    }

    return responses.get(
        user_input,
        "That's interesting! I am still learning about that."
    )

# Create web interface
demo = gr.Interface(
    fn=assistant,
    inputs=gr.Textbox(lines=1, placeholder="Ask about Math, Physics, or AI..."),
    outputs="text",
    title="Study AI Assistant",
    description="Ask me questions about Math, Physics, or AI!"
)

demo.launch()
